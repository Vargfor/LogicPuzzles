<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/lo_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lights Out"
            android:textColor="@color/colorText"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/lo_moves"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/colorLightsOut"
            android:textSize="14sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:text="Tap a light to toggle it and its neighbors. Turn all lights OFF!"/>

    <com.logicpuzzles.lightsout.LightsOutView
        android:id="@+id/lights_out_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"/>

    <Button
        android:id="@+id/btn_lo_reset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="Reset Puzzle"
        android:backgroundTint="@color/colorSurface"
        android:textColor="@color/colorText"/>

</LinearLayout>
